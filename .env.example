# Notion internal integration token (https://www.notion.so/my-integrations)
NOTION_TOKEN=

# Bearer token clients must send as: Authorization: Bearer <MCP_API_KEY>
# Generate one with: openssl rand -hex 32
MCP_API_KEY=

# Optional: enables the public playground (/demo/*) against a DEDICATED demo
# workspace — never your real one. Unset → demo routes respond 503.
DEMO_NOTION_TOKEN=

# Optional locally; Railway injects this in production
PORT=3000

# --- Only for `npm run smoke` (manual end-to-end test against a running server) ---
# MCP_URL=https://your-deployment.up.railway.app
# SMOKE_PARENT_PAGE_ID=   # enables create_page + append_blocks under this page
# SMOKE_DATABASE_ID=      # enables query_database against this database
